# Nuxt runtimeConfig examples
NUXT_SECRET_VALUE="super-secret-value" # This value will NOT be exposed to the client.
NUXT_VALUE="public-value" # This value will be exposed to the client.

# EMAIL CONFIGURATION
NUXT_NODEMAILER_FROM='"Universal Web Template" <no-reply@example.com>'
NUXT_NODEMAILER_HOST="smtp.example.com"
NUXT_NODEMAILER_PORT="587"
NUXT_NODEMAILER_SECURE="false"
NUXT_NODEMAILER_AUTH_USER="smtp-user"
NUXT_NODEMAILER_AUTH_PASS="change-me"

# AUTHENTICATION (KINDE)
NUXT_KINDE_CLIENT_ID=<your_kinde_client_id>
NUXT_KINDE_CLIENT_SECRET=<your_kinde_client_secret>
NUXT_KINDE_AUTH_DOMAIN=https://<your_kinde subdomain>.kinde.com
NUXT_KINDE_REDIRECT_URL=http://localhost:3000/api/callback
NUXT_KINDE_LOGOUT_REDIRECT_URL=http://localhost:3000
NUXT_KINDE_PASSWORD=<a random password which will be used to encrypt the session cookie>
NUXT_KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard