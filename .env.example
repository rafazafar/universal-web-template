# Nuxt runtimeConfig examples
# NUXT_APP_NAME -> runtimeConfig.appName
# NUXT_MAIL_TEST_TO -> runtimeConfig.mailTestTo
# NUXT_PUBLIC_SITE_URL -> runtimeConfig.public.siteUrl
# NUXT_PUBLIC_SUPPORT_EMAIL -> runtimeConfig.public.supportEmail
NUXT_APP_NAME="Universal Web Template"
NUXT_MAIL_TEST_TO="dev@example.com"
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
NUXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

# nuxt-nodemailer examples
# These override existing keys inside the `nodemailer` config in nuxt.config.ts
NUXT_NODEMAILER_FROM='"Universal Web Template" <no-reply@example.com>'
NUXT_NODEMAILER_HOST="smtp.example.com"
NUXT_NODEMAILER_PORT="587"
NUXT_NODEMAILER_SECURE="false"
NUXT_NODEMAILER_AUTH_USER="smtp-user"
NUXT_NODEMAILER_AUTH_PASS="change-me"
